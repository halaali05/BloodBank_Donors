rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // App data reads/writes go through Cloud Functions (Admin SDK).
      allow read: if false;
      allow write: if false; // only Admin SDK (Cloud Functions)
    }

    // Cooldown / restriction after donations (written by Cloud Functions only).
    match /donorDonationSchedule/{donorId} {
      allow read: if false;
      allow write: if false;
    }

    match /pending_profiles/{userId} {
      allow read: if false;
      allow write: if false; // only Admin SDK
    }

    match /requests/{requestId} {
      allow read: if false;
      allow write: if false;
      
      match /messages/{messageId} {
        allow read: if false;
        allow write: if false; // only Admin SDK (Cloud Functions)
      }
    }

    match /notifications/{userId}/user_notifications/{notificationId} {
      // Own notifications: read for real-time list sync; writes stay server-side only.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only Cloud Functions can write (create, update, delete)
    }

    // default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
